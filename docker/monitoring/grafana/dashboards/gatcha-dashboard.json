    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "id": 105,
      "title": "📈 Détail par endpoint",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Requêtes/s" },
            "properties": [{ "id": "unit", "value": "reqps" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "Latence moy. (s)" },
            "properties": [{ "id": "unit", "value": "s" }, { "id": "decimals", "value": 3 }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.5 }] } }, { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "gauge" } }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 50 },
      "id": 12,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Requêtes/s" }],
        "footer": { "show": false }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"gatcha-.*\", uri!~\"/actuator.*\"}[5m])) by (job, method, uri, status)",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_sum{job=~\"gatcha-.*\", uri!~\"/actuator.*\"}[5m])) by (job, method, uri, status) / sum(rate(http_server_requests_seconds_count{job=~\"gatcha-.*\", uri!~\"/actuator.*\"}[5m])) by (job, method, uri, status)",
          "format": "table",
          "instant": true,
          "legendFormat": "",
          "refId": "B"
        }
      ],
      "title": "Top endpoints par service",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "Time 1": true, "Time 2": true },
            "renameByName": {
              "job": "Service",
              "method": "Méthode",
              "uri": "URI",
              "status": "Statut",
              "Value #A": "Requêtes/s",
              "Value #B": "Latence moy. (s)"
            }
          }
        }
      ],
      "type": "table"
    },
